# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.

# --- Core ---
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/edgevault
UPLOAD_STORAGE_DIR=var/uploads

# --- Workspace gate ---
AUTH_OWNER_PASSWORD=
AUTH_DEMO_PASSWORD=
AUTH_SESSION_SECRET=

# --- OCR (optional) ---
# OCR_ENGINE=tesseract
# OCR_PDF_TEXT_THRESHOLD=20
# OCR_PDF_RENDER_DPI=200

# --- Embeddings / semantic search ---
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Assistant LLM tiers (optional) ---
# The rule-based parser always runs first. These enable escalation to an LLM
# only when the rules can't place a question. The LLM just picks a structured
# intent; the deterministic SQL still produces every number.

# Tier 2 — local model on the Hailo NPU via hailo-ollama (OpenAI-compatible).
# When the backend also runs on the Pi, the Hailo server is on localhost:8000,
# so run the backend on a different port to avoid it.
ASSISTANT_LLM_BASE_URL=http://localhost:8000/v1
ASSISTANT_LLM_MODEL=qwen2.5-instruct:1.5b
# ASSISTANT_LLM_TIMEOUT=30
# ASSISTANT_LLM_KEEP_WARM=true
# ASSISTANT_LLM_KEEP_WARM_INTERVAL=240

# Tier 3 — cloud fallback (We use DeepSeek in this project). 
# Stays disabled until a key is set.
ASSISTANT_FALLBACK_ENABLED=false
ASSISTANT_FALLBACK_BASE_URL=https://api.deepseek.com
ASSISTANT_FALLBACK_MODEL=DeepSeek-V4-Flash
DEEPSEEK_API_KEY=
